# =============================================================================
# Media Stack — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- User / Group ---
PUID=1000
PGID=1000
TZ=UTC

# --- Paths ---
# Relative to project root or absolute
CONFIG_DIR=./config
DATA_DIR=./data

# --- Gluetun VPN ---
# Supported providers: https://github.com/qdm12/gluetun-wiki
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_DNS=
SERVER_REGIONS=
# OpenVPN fallback (if not using WireGuard)
OPENVPN_USER=
OPENVPN_PASSWORD=
SERVER_COUNTRIES=

# --- qBittorrent ---
QBITTORRENT_USER=admin
QBITTORRENT_PASS=adminadmin

# --- Prowlarr ---
PROWLARR_API_KEY=

# --- Lidarr ---
LIDARR_API_KEY=

# --- slskd ---
SLSKD_USERNAME=
SLSKD_PASSWORD=

# --- Navidrome ---
ND_LOGIN_ENABLED=true
# username:password[,user2:pass2]
ND_USERS=admin:password

# --- Musicseerr ---
MUSICSEERR_API_KEY=

# --- Reverse Proxy (Caddy) ---
DOMAIN=music.example.com
CADDY_EMAIL=admin@example.com
# Cloudflare API Token for DNS-01 challenge (recommended)
CF_API_TOKEN=

# --- Cloudflare Tunnel ---
TUNNEL_TOKEN=
